{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brunoportis/localqueue/blob/main/release/evidence-manifest.schema.json",
  "title": "localqueue release evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "repository", "candidate_version", "candidate_sha",
    "candidate_parent_main_sha", "candidate_ref", "created_at", "workflow",
    "release_notes", "source_documents", "versions", "distributions", "reports",
    "required_jobs", "skipped_scenarios", "supported_platforms", "known_limitations",
    "open_issue_audit", "security_audit", "proposed_claims", "selected_claim",
    "overall_status"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "repository": {"const": "brunoportis/localqueue"},
    "candidate_version": {"const": "1.2.0"},
    "candidate_sha": {"$ref": "#/$defs/sha"},
    "candidate_parent_main_sha": {"$ref": "#/$defs/sha"},
    "candidate_ref": {"const": "release-candidate/v1.2.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "workflow": {
      "type": "object",
      "required": ["run_id", "url", "actor"],
      "properties": {
        "run_id": {"type": "integer", "minimum": 1},
        "url": {"type": "string", "format": "uri"},
        "actor": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "release_notes": {"$ref": "#/$defs/hashedPath"},
    "source_documents": {
      "type": "object",
      "required": ["changelog_sha256", "operational_envelope_sha256", "storage_policy_sha256", "uv_lock_sha256"],
      "properties": {
        "changelog_sha256": {"$ref": "#/$defs/sha256"},
        "operational_envelope_sha256": {"$ref": "#/$defs/sha256"},
        "storage_policy_sha256": {"$ref": "#/$defs/sha256"},
        "uv_lock_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "versions": {
      "type": "object",
      "required": ["python", "cargo", "native", "uv"],
      "properties": {
        "python": {"const": "1.2.0"},
        "cargo": {"const": "1.2.0"},
        "native": {"const": "1.2.0"},
        "uv": {"const": "1.2.0"}
      },
      "additionalProperties": false
    },
    "distributions": {"type": "array", "minItems": 26, "items": {"$ref": "#/$defs/distribution"}},
    "reports": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/hashedPath"}},
    "required_jobs": {"type": "object", "additionalProperties": {"const": "passed"}},
    "skipped_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "reason"],
        "properties": {"name": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}},
        "additionalProperties": false
      }
    },
    "supported_platforms": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "known_limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "open_issue_audit": {"type": "object"},
    "security_audit": {"type": "object"},
    "proposed_claims": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "selected_claim": {"type": ["string", "null"]},
    "overall_status": {"enum": ["passed", "failed"]}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "hashedPath": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}},
      "additionalProperties": false
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256", "size", "package_version", "python_tag", "abi_tag", "platform_tag", "source_candidate_sha", "build_job", "smoke_test_status"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 1},
        "package_version": {"const": "1.2.0"},
        "python_tag": {"type": "string"},
        "abi_tag": {"type": "string"},
        "platform_tag": {"type": "string"},
        "source_candidate_sha": {"$ref": "#/$defs/sha"},
        "build_job": {"type": "string", "minLength": 1},
        "smoke_test_status": {"enum": ["passed", "built-not-smoke-tested", "artifact-validated-not-physical-smoke", "not-applicable"]}
      }
    }
  }
}
